# 🧠 Engram Configuration

# --- Storage ---
# Path to the SQLite database file (default: ~/.engram/memory.db)
# ENGRAM_DB_PATH=./data/memory.db

# --- Semantic Search (Ollama) ---
# URL for the Ollama API (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Embedding model to use (default: nomic-embed-text)
# OLLAMA_MODEL=nomic-embed-text

# --- Performance & Limits ---
# Maximum number of characters to return in MCP search results to prevent context bloat
# ENGRAM_MAX_CONTEXT_CHARS=8000

# --- Measuring impact (optional) ---
# Append one JSON line per hybrid search (query, top hits, source mcp|cli)
# ENGRAM_AUDIT_LOG=~/.engram/search-audit.jsonl
# Append Session Help Score lines (see `engram session-help`)
# ENGRAM_SESSION_HELP_LOG=~/.engram/session-help.jsonl
# Commit/PR disclosure: use titles only on public repos (see docs/MEASURING_FIT_AND_HELP.md)
# ENGRAM_DISCLOSURE=public
# ENGRAM_DISCLOSURE=private

# --- Integrations ---
# Path to the Claw-Code binary (optional, will auto-detect if in standard location)
# CLAW_PATH=/usr/local/bin/claw
# DEEPSEEK_API_KEY=sk-your-key-here
